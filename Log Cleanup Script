#!/bin/bash
#
# log_cleanup.sh - Find and clean up old log files
# Usage: ./log_cleanup.sh /path/to/logs [days] [--dry-run]
#
# Compresses logs older than N days (default 7), and deletes
# compressed logs older than 30 days. Use --dry-run to preview
# changes without making them.

set -euo pipefail

LOG_DIR="${1:?Usage: $0 /path/to/logs [days] [--dry-run]}"
DAYS="${2:-7}"
DRY_RUN="${3:-}"

if [ ! -d "$LOG_DIR" ]; then
    echo "Error: Directory $LOG_DIR does not exist."
    exit 1
fi

echo "Scanning $LOG_DIR for logs older than $DAYS days..."

# Compress old uncompressed logs
find "$LOG_DIR" -type f -name "*.log" -mtime +"$DAYS" | while read -r FILE; do
    if [ "$DRY_RUN" == "--dry-run" ]; then
        echo "[DRY-RUN] Would compress: $FILE"
    else
        gzip "$FILE"
        echo "Compressed: $FILE"
    fi
done

# Delete compressed logs older than 30 days
find "$LOG_DIR" -type f -name "*.log.gz" -mtime +30 | while read -r FILE; do
    if [ "$DRY_RUN" == "--dry-run" ]; then
        echo "[DRY-RUN] Would delete: $FILE"
    else
        rm -f "$FILE"
        echo "Deleted: $FILE"
    fi
done

echo "Log cleanup completed."
