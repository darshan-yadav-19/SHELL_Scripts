#!/bin/bash
# Quick system health snapshot - run manually or via cron
# Last updated: covers cpu/mem/disk + top consumers

set -eu

HOST=$(hostname)
echo "Health check - $HOST - $(date '+%Y-%m-%d %H:%M:%S')"
echo "------------------------------------------------"

echo "Load average:"
uptime | awk -F'load average:' '{print $2}'

echo ""
echo "Memory:"
free -h | grep -v Swap

echo ""
echo "Disk usage (mounted filesystems):"
df -h | grep -E '^/dev/'

echo ""
echo "Top 5 CPU consumers:"
ps -eo pid,comm,%cpu,%mem --sort=-%cpu | head -6

echo ""
echo "Top 5 memory consumers:"
ps -eo pid,comm,%cpu,%mem --sort=-%mem | head -6
