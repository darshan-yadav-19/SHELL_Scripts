#!/bin/bash
# Standard SSH hardening - disables root login + password auth
# Make sure your key-based login works BEFORE running this on a remote box
# Backs up sshd_config and reverts automatically if the new config fails the test

set -eu

CFG=/etc/ssh/sshd_config
BAK="$CFG.bak.$(date +%Y%m%d%H%M%S)"

[ "$EUID" -eq 0 ] || { echo "run as root"; exit 1; }

cp "$CFG" "$BAK"
echo "backup saved at $BAK"

set_opt() {
    if grep -qE "^\s*#?\s*$1\s+" "$CFG"; then
        sed -i "s/^\s*#\?\s*$1\s\+.*/$1 $2/" "$CFG"
    else
        echo "$1 $2" >> "$CFG"
    fi
}

set_opt PermitRootLogin no
set_opt PasswordAuthentication no
set_opt PermitEmptyPasswords no
set_opt X11Forwarding no
set_opt MaxAuthTries 3
set_opt ClientAliveInterval 300
set_opt ClientAliveCountMax 2

if sshd -t; then
    systemctl restart sshd
    echo "hardening applied, sshd restarted"
else
    cp "$BAK" "$CFG"
    echo "config test failed, reverted"
    exit 1
fi
